# Backend base URL (used by the Next.js `/api/game/*` proxy)
GAME_API_BASE=https://homoeomorphic-especially-felecia.ngrok-free.dev

# Optional: only needed if you want to call backend directly from the browser (not recommended due to CORS)
NEXT_PUBLIC_GAME_API_BASE=https://homoeomorphic-especially-felecia.ngrok-free.dev
